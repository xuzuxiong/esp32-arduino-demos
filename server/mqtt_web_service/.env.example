# Flask application
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=false
FLASK_PORT=8000

# Generate your own secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_FLASK_SECRET_KEY

# PostgreSQL (example — use your own credentials)
SQLALCHEMY_DATABASE_URI=postgresql://mqtt_user:YOUR_DB_PASSWORD@localhost:5432/mqtt_service_db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# MQTT broker (must match firmware config.h when using network mode)
MQTT_BROKER_URL=192.168.1.100
MQTT_BROKER_PORT=1883
MQTT_USERNAME=YOUR_MQTT_USERNAME
MQTT_PASSWORD=YOUR_MQTT_PASSWORD
MQTT_KEEPALIVE=60

# Set false to skip MQTT threads during local UI development
ENABLE_MQTT=True

# Celery / Redis (optional background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional registration freeze (demo / maintenance mode)
FREEZE_MODE=false
FREEZE_CUTOFF_DATE=2099-01-01
FREEZE_BYPASS_KEY=YOUR_ADMIN_BYPASS_KEY
OFFICIAL_INVITE=YOUR_INVITE_CODE
